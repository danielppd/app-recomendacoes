{
  "expo": {
    "name": "Bubble",
    "slug": "bubble-mobile",
    "scheme": "bubble",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "android": {
      "package": "com.danielppd.bubble",
      "adaptiveIcon": {
        "backgroundColor": "#0f0f0f",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.danielppd.bubble"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "O Bubble usa sua localização para considerar o clima e o horário ao montar suas recomendações."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#a855f7"
        }
      ]
    ]
  }
}
